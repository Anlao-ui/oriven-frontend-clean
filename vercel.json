{
  "redirects": [
    { "source": "/app",      "destination": "/", "permanent": true },
    { "source": "/app/(.*)", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/welcome",  "destination": "/index.html" },
    { "source": "/demo",     "destination": "/demo/index.html" },
    { "source": "/demo/",    "destination": "/demo/index.html" },
    { "source": "/(.*)",     "destination": "/app.html" }
  ]
}
