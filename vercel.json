{
  "rewrites": [
    { "source": "/app",      "destination": "/app.html" },
    { "source": "/app/(.*)", "destination": "/app.html" },
    { "source": "/demo",     "destination": "/demo/index.html" },
    { "source": "/demo/",    "destination": "/demo/index.html" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ]
}
